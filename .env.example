# Copy to `.env` and adjust per environment. All variables are read by
# pydantic-settings via the `PLAYERCOUNT_` prefix.

# ---- Paths ----
PLAYERCOUNT_YOLO_WEIGHTS=./models/yolov8m-soccer.pt
PLAYERCOUNT_SIGLIP_MODEL_ID=google/siglip-base-patch16-224
PLAYERCOUNT_WEIGHTS_DIR=./models
PLAYERCOUNT_TEAMS_CLUSTERER_PATH=./models/teams.joblib

# Optional YAML overlay applied below `Settings` defaults but above env vars.
# PLAYERCOUNT_CONFIG_FILE=./configs/default.yaml

# ---- Device / perf ----
# auto | cpu | cuda
PLAYERCOUNT_DEVICE=auto
PLAYERCOUNT_YOLO_BATCH_SIZE=8
PLAYERCOUNT_SIGLIP_BATCH_SIZE=64
PLAYERCOUNT_SAMPLING_STRIDE=1
PLAYERCOUNT_QUEUE_MAXSIZE=8
# Leave unset to use min(8, cpu_count + 4)
# PLAYERCOUNT_EXECUTOR_MAX_WORKERS=8

# ---- Detection thresholds ----
PLAYERCOUNT_DET_CONF=0.35
PLAYERCOUNT_DET_IOU=0.5

# ---- Aggregation ----
PLAYERCOUNT_TRACK_WINDOW=30
PLAYERCOUNT_CLUSTER_MIN_SAMPLES=60
PLAYERCOUNT_UMAP_COMPONENTS=3
PLAYERCOUNT_KMEANS_RANDOM_STATE=42

# ---- Logging ----
PLAYERCOUNT_LOG_LEVEL=INFO
PLAYERCOUNT_LOG_JSON=true
